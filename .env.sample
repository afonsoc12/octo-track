# Required
OCTOPUS_API_KEY=

# Optional: PostgreSQL (required for stateful/fetch mode)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=octopus
# POSTGRES_PASSWORD=octopus
# POSTGRES_DB=octopus_energy

# Optional: logging
# LOG_LEVEL=INFO       # DEBUG, INFO, WARNING, ERROR
# LOG_FORMAT=text      # text or logfmt (logfmt recommended for Docker)
